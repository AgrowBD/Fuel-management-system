generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Reference Tables (dummy government databases, read-only) ─────────────

model BrtaVehicle {
  id            String      @id @default(cuid())
  licenseNumber String      @unique
  ownerNid      String
  ownerName     String
  vehicleType   VehicleType
  make          String
  model         String
  year          Int
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())

  @@map("brta_vehicles")
}

model PumpRegistry {
  id             String   @id @default(cuid())
  tradeLicenseNo String   @unique
  pumpName       String
  ownerName      String
  division       String
  district       String
  address        String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@map("pump_registry")
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum Role {
  VEHICLE_OWNER
  OPERATOR
  ADMIN
}

enum VehicleType {
  MOTORCYCLE
  CNG_AUTO_RICKSHAW
  CAR
  MICROBUS
  TRUCK
  BUS
}

enum TransactionStatus {
  APPROVED
  BLOCKED
  PARTIAL
}

// ─── Core Application Tables ──────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  phone        String?
  role         Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  operatorProfile OperatorProfile?
  transactions    FuelTransaction[] @relation("OperatorTransactions")

  @@map("users")
}

model OperatorProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  tradeLicenseNo String   @unique
  pumpName       String
  pumpAddress    String
  division       String
  district       String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("operator_profiles")
}

// Vehicles are pre-seeded and linked to the single owner account in V1
model Vehicle {
  id            String      @id @default(cuid())
  licenseNumber String      @unique
  vehicleType   VehicleType
  make          String
  model         String
  year          Int
  ownerName     String      // denormalized from BRTA for display
  isActive      Boolean     @default(true)
  registeredAt  DateTime    @default(now())

  transactions FuelTransaction[]
  schedules    FuelSchedule[]

  @@map("vehicles")
}

// Admin-editable quota rules per vehicle type
model DistributionRule {
  id                String      @id @default(cuid())
  vehicleType       VehicleType @unique
  maxLitersPerCycle Float
  restrictionDays   Int
  description       String?
  updatedAt         DateTime    @updatedAt

  @@map("distribution_rules")
}

model FuelTransaction {
  id              String            @id @default(cuid())
  vehicleId       String
  operatorId      String
  litersRequested Float
  litersDispensed Float
  status          TransactionStatus
  pumpName        String            // denormalized for historical accuracy
  pumpDistrict    String
  transactedAt    DateTime          @default(now())
  notes           String?

  vehicle  Vehicle @relation(fields: [vehicleId], references: [id])
  operator User    @relation("OperatorTransactions", fields: [operatorId], references: [id])

  @@index([vehicleId, transactedAt])
  @@index([operatorId, transactedAt])
  @@map("fuel_transactions")
}

model FuelSchedule {
  id            String   @id @default(cuid())
  vehicleId     String
  pumpName      String
  pumpDistrict  String
  scheduledDate DateTime
  timeSlot      String   // e.g. "09:00-10:00"
  isCompleted   Boolean  @default(false)
  isCancelled   Boolean  @default(false)
  createdAt     DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, scheduledDate])
  @@map("fuel_schedules")
}
