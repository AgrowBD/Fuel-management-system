generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Reference Tables (dummy government databases, read-only) ─────────────

// Role values: VEHICLE_OWNER | OPERATOR | ADMIN
// VehicleType values: MOTORCYCLE | CNG_AUTO_RICKSHAW | CAR | MICROBUS | TRUCK | BUS
// TransactionStatus values: APPROVED | BLOCKED | PARTIAL
// SQLite does not support enums; values are validated in application code via TypeScript constants.

model BrtaVehicle {
  id            String   @id @default(cuid())
  licenseNumber String   @unique
  ownerNid      String
  ownerName     String
  vehicleType   String   // VehicleType
  make          String
  model         String
  year          Int
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@map("brta_vehicles")
}

model PumpRegistry {
  id             String   @id @default(cuid())
  tradeLicenseNo String   @unique
  pumpName       String
  ownerName      String
  division       String
  district       String
  address        String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@map("pump_registry")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  fullName     String
  phone        String?
  role         String   // Role
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  operatorProfile OperatorProfile?
  transactions    FuelTransaction[] @relation("OperatorTransactions")

  @@map("users")
}

model OperatorProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  tradeLicenseNo String   @unique
  pumpName       String
  pumpAddress    String
  division       String
  district       String
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("operator_profiles")
}

model Vehicle {
  id            String   @id @default(cuid())
  licenseNumber String   @unique
  vehicleType   String   // VehicleType
  make          String
  model         String
  year          Int
  ownerName     String
  isActive      Boolean  @default(true)
  registeredAt  DateTime @default(now())

  transactions FuelTransaction[]
  schedules    FuelSchedule[]

  @@map("vehicles")
}

model DistributionRule {
  id                String   @id @default(cuid())
  vehicleType       String   @unique // VehicleType
  maxLitersPerCycle Float
  restrictionDays   Int
  description       String?
  updatedAt         DateTime @updatedAt

  @@map("distribution_rules")
}

model FuelTransaction {
  id              String   @id @default(cuid())
  vehicleId       String
  operatorId      String
  litersRequested Float
  litersDispensed Float
  status          String   // TransactionStatus
  pumpName        String
  pumpDistrict    String
  transactedAt    DateTime @default(now())
  notes           String?

  vehicle  Vehicle @relation(fields: [vehicleId], references: [id])
  operator User    @relation("OperatorTransactions", fields: [operatorId], references: [id])

  @@index([vehicleId, transactedAt])
  @@index([operatorId, transactedAt])
  @@map("fuel_transactions")
}

model FuelSchedule {
  id            String   @id @default(cuid())
  vehicleId     String
  pumpName      String
  pumpDistrict  String
  scheduledDate DateTime
  timeSlot      String
  isCompleted   Boolean  @default(false)
  isCancelled   Boolean  @default(false)
  createdAt     DateTime @default(now())

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@index([vehicleId, scheduledDate])
  @@map("fuel_schedules")
}
